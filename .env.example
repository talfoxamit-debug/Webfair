# Supabase — used by the /api/leads route to store audit-request submissions.
# Copy to .env.local for local dev; set the same vars in Vercel for production.
# The service-role key is SERVER-ONLY — never prefix it with NEXT_PUBLIC_.

SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Expected `leads` table columns (adjust the API route if yours differ):
#   id          uuid        primary key, default gen_random_uuid()
#   created_at  timestamptz default now()
#   name        text
#   email       text
#   website     text        nullable
#   message     text        nullable
#   source      text        e.g. 'audit_form'
