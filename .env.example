# ── Supabase ─────────────────────────────────────────────────────────────────
# Used by /api/leads (form → CRM), /api/audit (audit logging) and /crm.
# Copy to .env.local for local dev; set the same vars in Vercel for production.
# The service-role key is SERVER-ONLY, never prefix it with NEXT_PUBLIC_.

SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Internal CRM (/crm) ───────────────────────────────────────────────────────
# Any long random string. Required to open the /crm pipeline board and to call
# GET/PATCH /api/leads. Generate with: openssl rand -hex 24

CRM_ACCESS_KEY=change-me-long-random-string

# ── Database schema ───────────────────────────────────────────────────────────
# Run once in the Supabase SQL editor:
#
#   create table if not exists leads (
#     id          uuid primary key default gen_random_uuid(),
#     created_at  timestamptz not null default now(),
#     name        text not null,
#     email       text not null,
#     website     text,
#     message     text,
#     source      text,
#     status      text not null default 'new',   -- new|contacted|call_booked|proposal|won|lost
#     notes       text
#   );
#
#   create table if not exists audits (
#     id          uuid primary key default gen_random_uuid(),
#     created_at  timestamptz not null default now(),
#     url         text not null,
#     score       int,
#     load_ms     int,
#     page_kb     int
#   );
#
# Keep RLS enabled with NO public policies on both tables, the app only ever
# touches them server-side with the service-role key.

# Full, ready-to-paste schema also lives in supabase/schema.sql.

# ── Resend (emails the full audit report to the visitor) ─────────────────────
# Powers the audit → full-report → CRM funnel (/api/audit-report).
# From resend.com → API Keys. REPORT_FROM_EMAIL must be on a domain verified in
# Resend. REPORT_NOTIFY_EMAIL is optional, where new-lead alerts are sent.
# Until these are set, the funnel still captures the lead and confirms; it just
# can't auto-send the report email yet.

RESEND_API_KEY=re_your_api_key
REPORT_FROM_EMAIL=Stackwrk <audit@stackwrk.com>
REPORT_NOTIFY_EMAIL=you@yourdomain.com

# ── Stripe (care-plan subscriptions) ─────────────────────────────────────────
# No API keys needed. Create 3 recurring Payment Links in the Stripe dashboard
# ($99/$249/$499 monthly) and paste the URLs into `carePlans[].stripeUrl` in
# src/lib/pricing.ts, "Subscribe now" buttons appear automatically.
